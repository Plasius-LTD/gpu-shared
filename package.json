{
  "name": "@plasius/gpu-shared",
  "version": "0.1.6",
  "description": "Shared browser-safe demo runtime and asset helpers for the Plasius gpu-* package family.",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./src/index.d.ts",
  "files": [
    "dist",
    "src",
    "assets",
    "README.md",
    "CHANGELOG.md",
    "LICENSE",
    "legal"
  ],
  "exports": {
    ".": {
      "types": "./src/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./assets/brigantine.gltf": "./assets/brigantine.gltf",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsup",
    "demo": "python3 -m http.server --directory ..",
    "demo:example": "node demo/example.js",
    "typecheck": "node --check src/index.js && node --check src/showcase-runtime.js && node --check src/gltf-loader.js && node --check demo/main.js",
    "audit:eslint": "eslint . --max-warnings=0",
    "audit:deps": "npm ls --all --omit=optional --omit=peer > /dev/null 2>&1 || true",
    "audit:npm": "npm audit --audit-level=high --omit=dev",
    "audit:test": "npm run test:coverage",
    "lint": "eslint . --max-warnings=0 && node --check demo/main.js",
    "test": "npm run test:unit",
    "test:unit": "node --test",
    "test:coverage": "c8 --reporter=lcov --reporter=text node --test",
    "pack:check": "node scripts/verify-public-package.cjs",
    "prepublishOnly": "npm run build && npm run pack:check"
  },
  "keywords": [
    "webgpu",
    "gpu",
    "shared",
    "demo",
    "showcase",
    "gltf",
    "plasius"
  ],
  "author": "Plasius LTD <development@plasius.co.uk>",
  "license": "Apache-2.0",
  "dependencies": {
    "@plasius/gpu-cloth": "^0.1.1",
    "@plasius/gpu-debug": "^0.1.2",
    "@plasius/gpu-fluid": "^0.1.1",
    "@plasius/gpu-lighting": "^0.1.14",
    "@plasius/gpu-performance": "^0.1.3",
    "@plasius/gpu-physics": "^0.1.10"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "c8": "^11.0.0",
    "eslint": "^10.1.0",
    "globals": "^17.3.0",
    "tsup": "^8.5.0",
    "typescript": "^6.0.2"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Plasius-LTD/gpu-shared.git"
  },
  "bugs": {
    "url": "https://github.com/Plasius-LTD/gpu-shared/issues"
  },
  "homepage": "https://github.com/Plasius-LTD/gpu-shared#readme",
  "publishConfig": {
    "access": "public"
  },
  "funding": [
    {
      "type": "patreon",
      "url": "https://www.patreon.com/c/plasiusltd/membership"
    },
    {
      "type": "github",
      "url": "https://github.com/sponsors/Plasius-LTD"
    }
  ],
  "overrides": {
    "minimatch": "^10.2.1"
  },
  "engines": {
    "node": ">=24"
  }
}
